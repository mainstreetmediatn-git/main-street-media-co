# Optional hosted scraper for api/lead-crawl.ts. Set the same variable in Vercel
# for production; do not commit the real key.
FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev/v2

# Optional CRM Google Drive delivery for api/lead-crawl.ts.
# Deploy a Google Apps Script web app that can write to the CRM Drive folder,
# then set its web app URL here. Keep the secret out of source control.
# If you receive GOOGLE_APPS_SCRIPT_WEB_APP_URL, map it to this canonical name.
LEAD_CRAWL_GOOGLE_DRIVE_WEBHOOK_URL=
LEAD_CRAWL_GOOGLE_DRIVE_WEBHOOK_SECRET=

# Public site adapter modes for api/lead-audit.ts.
# LIVE mode is active when CRM_WEBHOOK_URL is present.
CRM_WEBHOOK_URL=
CRM_API_KEY=
LEAD_AUDIT_SANDBOX=true
LEAD_AUDIT_DISABLED=false

# Client-visible URLs must use the VITE_ prefix in this Vite app.
VITE_PORTAL_URL=https://dashboard-two-beige-24.vercel.app
VITE_CALENDLY_URL=
